# Copy this file to ".env" and fill in values to enable real AI vision analysis.
# If no key is provided, the app runs in DEMO mode with a rich sample analysis.

# Port the API server listens on
PORT=4000

# OpenAI-compatible vision API (optional). When set, photos are analyzed by a real model.
# Works with OpenAI or any OpenAI-compatible endpoint (set OPENAI_BASE_URL accordingly).
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini


# --- Accounts & data ---
# Directory for the JSON data store (users, plants, push subscriptions).
# Defaults to ./data if unset.
DATA_DIR=

# --- Web Push (background watering reminders) ---
# If left blank, the server auto-generates a VAPID key pair on first run and
# persists it in the data store. To use fixed keys, generate a pair with:
#   npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@plantpal.example
