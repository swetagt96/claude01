{
  "name": "plant-care-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Backend API for the Plant Care & Watering app",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
